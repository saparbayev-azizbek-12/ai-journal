---
import '../styles/components/footer.css';
import { Github, Linkedin, Mail, Send } from 'lucide-astro';

const currentYear = new Date().getFullYear();

const socialLinks = [
  { icon: Github,   href: 'https://github.com/saparbayev-azizbek-12',                  label: 'GitHub' },
  { icon: Linkedin, href: 'https://www.linkedin.com/in/azizbek-saparbayev-9a3300357/', label: 'LinkedIn' },
  { icon: Send,     href: 'https://t.me/saparbayev_azizbek',                           label: 'Telegram' },
  { icon: Mail,     href: 'mailto:saparbayev.azizbek12@gmail.com',                     label: 'Email' },
];

const quickLinks = [
  { name: 'ML Learning Path', href: '/ml-learning-path' },
  { name: 'DL Learning Path', href: '/dl-learning-path' },
  { name: 'Projects',         href: '/projects' },
  { name: 'About Me',         href: '/about' },
];
---

<footer class="footer-root">
  <div class="footer-inner">
    <div class="footer-grid">

      <div>
        <a href="/" class="footer-logo">AI <em>Journal</em></a>
        <p class="footer-desc">
          Documenting the journey of a Machine Learning enthusiast. Sharing insights, projects, and learning paths.
        </p>
      </div>

      <div>
        <h4 class="footer-heading">Navigation</h4>
        <ul class="footer-links">
          {quickLinks.map(link => (
            <li><a href={link.href}>{link.name}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="footer-heading">Connect</h4>
        <div class="social-row">
          {socialLinks.map(s => (
            <a href={s.href} aria-label={s.label} target="_blank" rel="noopener noreferrer" class="social-link">
              <s.icon class="w-4 h-4" />
            </a>
          ))}
        </div>
      </div>

    </div>

    <div class="footer-bottom">
      <span>© {currentYear} AI Journal</span>
      <span>Built with Astro</span>
    </div>
  </div>
</footer>

---
import '../styles/components/project-card.css';
import { ArrowRight, Github, Monitor } from 'lucide-astro';

interface Props {
  title: string;
  description: string;
  image: string;
  tags: string[];
  githubLink: string;
  demoLink?: string;
  slug: string;
}

const { title, description, image, tags, githubLink, demoLink, slug } = Astro.props;
---

<div class="project-card">
  <div class="card-image">
    <img src={image} alt={title} loading="lazy" />
  </div>

  <div class="card-body">
    <div class="card-tags">
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
    <h3 class="card-title">{title}</h3>
    <p class="card-desc">{description}</p>

    <div class="card-footer">
      <div class="card-links">
        <a href={githubLink} target="_blank" rel="noopener noreferrer" class="icon-link" aria-label="GitHub">
          <Github class="w-4 h-4" />
        </a>
        {demoLink && (
          <a href={demoLink} target="_blank" rel="noopener noreferrer" class="icon-link" aria-label="Live Demo">
            <Monitor class="w-4 h-4" />
          </a>
        )}
      </div>
      <a href={`/projects/${slug}`} class="card-detail-link">
        Details
        <ArrowRight class="w-3.5 h-3.5" />
      </a>
    </div>
  </div>
</div>

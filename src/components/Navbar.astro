---
import '../styles/components/navbar.css';
import ThemeToggle from './ThemeToggle.astro';

const { pathname } = Astro.url;

const navItems = [
  { name: 'Home',     href: '/' },
  { name: 'ML Path',  href: '/ml-learning-path' },
  { name: 'DL Path',  href: '/dl-learning-path' },
  { name: 'Projects', href: '/projects' },
  { name: 'About',    href: '/about' },
];

function isActive(href: string) {
  if (href === '/' && pathname !== '/') return false;
  return pathname.startsWith(href);
}
---

<nav class="nav-root">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      AI <em>Journal</em>
    </a>

    <ul class="nav-links" id="nav-links">
      {navItems.map((item) => (
        <li>
          <a href={item.href} class={`nav-link ${isActive(item.href) ? 'nav-link--active' : ''}`}>
            {item.name}
          </a>
        </li>
      ))}
    </ul>

    <div class="nav-right">
      <ThemeToggle />
      <button class="nav-hamburger" id="mobile-menu-button" aria-label="Menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    {navItems.map((item) => (
      <a href={item.href} class={`mobile-link ${isActive(item.href) ? 'mobile-link--active' : ''}`}>
        {item.name}
      </a>
    ))}
  </div>
</nav>

<script>
  import { setupMobileMenu } from '../scripts/mobile-menu';
  setupMobileMenu();
  document.addEventListener('astro:after-swap', setupMobileMenu);
</script>

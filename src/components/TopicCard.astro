---
import '../styles/components/topic-card.css';
import { ExternalLink, Github } from 'lucide-astro';
import CodeBlock from './CodeBlock.astro';

interface Props {
  title: string;
  description: string;
  concepts: string[];
  code: string;
  githubLink: string;
  demoLink?: string;
  index: number;
}

const { title, description, concepts, code, githubLink, demoLink, index } = Astro.props;
---

<div class="topic-card">
  <div class="topic-header">
    <div class="topic-index">
      <span>{String(index).padStart(2, '0')}</span>
    </div>
    <div class="topic-meta">
      <h3 class="topic-title">{title}</h3>
      <p class="topic-desc">{description}</p>
    </div>
  </div>

  <div class="concept-list">
    {concepts.map(concept => (
      <span class="tag-pill">{concept}</span>
    ))}
  </div>

  <div class="topic-code-wrap">
    <CodeBlock code={code} />
  </div>

  <div class="topic-actions">
    <a href={githubLink} target="_blank" rel="noopener noreferrer" class="topic-btn-ghost">
      <Github class="w-3.5 h-3.5" />
      View Notebook
    </a>
    {demoLink && (
      <a href={demoLink} target="_blank" rel="noopener noreferrer" class="topic-btn-primary">
        <ExternalLink class="w-3.5 h-3.5" />
        Live Demo
      </a>
    )}
  </div>
</div>

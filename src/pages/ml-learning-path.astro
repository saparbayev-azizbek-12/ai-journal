---
import '../styles/pages/path.css';
import Layout from '../layouts/Layout.astro';
import TopicCard from '../components/TopicCard.astro';
import { getCollection } from 'astro:content';

const topics = await getCollection('topics');
const sortedTopics = topics
  .filter(topic => topic.data.order <= 12)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout title="ML Learning Path" description="Follow the machine learning journey from basics to advanced clustering.">
  <div class="path-wrap">

    <div class="path-header">
      <span class="path-num">02 — Learning</span>
      <h1 class="path-title">Machine Learning <em>Topics</em></h1>
      <p class="path-sub">
        A curated path from foundational regression models to advanced unsupervised learning.
        Each topic includes core concepts, sample implementation, and a link to the full notebook.
      </p>
    </div>

    <hr class="path-rule" />

    <div class="topics-grid">
      {sortedTopics.map((topic) => (
        <TopicCard
          index={topic.data.order}
          title={topic.data.title}
          description={topic.data.description}
          concepts={topic.data.concepts}
          code={topic.data.code}
          githubLink={topic.data.githubLink}
          demoLink={topic.data.demoLink}
        />
      ))}
    </div>

  </div>
</Layout>

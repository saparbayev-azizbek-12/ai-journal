---
import '../styles/pages/about.css';
import Layout from '../layouts/Layout.astro';
import { Mail, Github, Linkedin, Send } from 'lucide-astro';

const experience = [
  { company: 'AmuSoft',         role: 'Backend Developer',  period: '2024 – 2026' },
  { company: 'MAAB Innovation', role: 'Database Developer', period: '2025 – Present' },
];

const education = [
  {
    school: 'Urgench Branch of Tashkent University of Information Technologies',
    degree: 'Bachelor of Software Engineering',
    period: '2022 – 2026',
  },
];
---

<Layout title="About Me" description="Learn more about the creator of AI Journal and my background in Machine Learning.">
  <div class="about-wrap">

    <div class="page-header">
      <span class="page-num">03 — About</span>
      <h1 class="page-title">Azizbek <em>Saparbayev</em></h1>
      <p class="page-sub">Backend Developer &amp; Machine Learning Enthusiast based in Uzbekistan.</p>
    </div>

    <hr class="about-rule" />

    <div class="two-col">
      <div class="col">
        <h2 class="col-heading">Experience</h2>
        <div class="timeline">
          {experience.map(item => (
            <div class="timeline-item">
              <div class="timeline-dot"></div>
              <div class="timeline-body">
                <p class="timeline-period">{item.period}</p>
                <h3 class="timeline-role">{item.role}</h3>
                <p class="timeline-company">{item.company}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="col">
        <h2 class="col-heading">Education</h2>
        <div class="timeline">
          {education.map(item => (
            <div class="timeline-item">
              <div class="timeline-dot"></div>
              <div class="timeline-body">
                <p class="timeline-period">{item.period}</p>
                <h3 class="timeline-role">{item.degree}</h3>
                <p class="timeline-company">{item.school}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <hr class="about-rule" />

    <div class="contact-section">
      <div class="contact-left">
        <span class="contact-num">04 — Contact</span>
        <h2 class="contact-title">Let's work <em>together</em></h2>
      </div>
      <div class="contact-right">
        <p class="contact-desc">
          I'm always open to discussing new projects, creative ideas, or opportunities to be part of your vision.
        </p>
        <div class="contact-btns">
          <a href="mailto:saparbayev.azizbek12@gmail.com" class="about-btn-primary">
            <Mail class="w-4 h-4" /> Send Email
          </a>
          <a href="https://github.com/saparbayev-azizbek-12" target="_blank" rel="noopener" class="about-btn-outline">
            <Github class="w-4 h-4" /> GitHub
          </a>
          <a href="https://www.linkedin.com/in/azizbek-saparbayev-9a3300357/" target="_blank" rel="noopener" class="about-btn-outline">
            <Linkedin class="w-4 h-4" /> LinkedIn
          </a>
          <a href="https://t.me/saparbayev_azizbek" target="_blank" rel="noopener" class="about-btn-outline">
            <Send class="w-4 h-4" /> Telegram
          </a>
        </div>
      </div>
    </div>

  </div>
</Layout>

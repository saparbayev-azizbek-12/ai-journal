---
import Layout from '../layouts/Layout.astro';
import { Mail, Github, Linkedin, Calendar, MapPin } from 'lucide-astro';

const experience = [
  { company: 'AmuSoft', role: 'Backend Developer', period: '2024 - 2026' },
  { company: 'MAAB Innovation', role: 'Database Developer', period: '2025 - Present' },
];

const education = [
  { school: 'Urgench Branch of Tashkent University of Information Technologies', degree: 'Bachelor of Software Engineering', period: '2022 - 2026' },
];
---

<Layout title="About Me" description="Learn more about the creator of AI Journal and my background in Machine Learning.">
  <div class="max-w-4xl mx-auto py-12 space-y-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 pt-8">
      <div class="space-y-8">
        <h2 class="text-2xl font-bold border-b border-white/5 pb-4">Experience</h2>
        <div class="space-y-6">
          {experience.map(item => (
            <div class="relative pl-6 border-l border-slate-800">
              <div class="absolute -left-[5px] top-1.5 w-2 h-2 rounded-full bg-brand-accent-primary"></div>
              <h3 class="font-bold text-white">{item.role}</h3>
              <p class="text-brand-accent-primary text-sm font-medium">{item.company}</p>
              <p class="text-slate-500 text-xs mt-1">{item.period}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="space-y-8">
        <h2 class="text-2xl font-bold border-b border-white/5 pb-4">Education</h2>
        <div class="space-y-6">
          {education.map(item => (
            <div class="relative pl-6 border-l border-slate-800 hover:border-brand-accent-secondary/50 transition-colors">
              <div class="absolute -left-[5px] top-1.5 w-2.5 h-2.5 rounded-full bg-brand-accent-secondary shadow-[0_0_10px_rgba(6,182,212,0.5)]"></div>
              <h3 class="font-bold text-white text-lg">{item.degree}</h3>
              <p class="text-brand-accent-secondary text-sm font-medium">{item.school}</p>
              <p class="text-slate-500 text-xs mt-1">{item.period}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="glass-card p-8 rounded-3xl text-center space-y-6">
      <h2 class="text-2xl font-bold">Let's work together</h2>
      <p class="text-slate-400 max-w-lg mx-auto">
        I'm always open to discussing new projects, creative ideas or opportunities to be part of your visions.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="saparbayev.azizbek12@gmail.com" class="btn-primary flex items-center gap-2">
          <Mail class="w-4 h-4" />
          Send Email
        </a>
        <a href="https://github.com/saparbayev-azizbek-12" class="btn-ghost flex items-center gap-2">
          <Github class="w-4 h-4" />
          GitHub
        </a>
        <a href="https://www.linkedin.com/in/azizbek-saparbayev-9a3300357/" class="btn-ghost flex items-center gap-2">
          <Linkedin class="w-4 h-4" />
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import { Home } from 'lucide-astro';
---

<Layout title="404 - Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="min-h-[70vh] flex flex-col items-center justify-center py-16 px-4 text-center">
    <div class="space-y-6 max-w-md mx-auto">
      <h1 class="text-7xl md:text-7xl font-extrabold tracking-tight gradient-text">
        404
      </h1>
      
      <h2 class="text-2xl md:text-3xl font-bold text-white tracking-tight">
        Page Not Found
      </h2>
      
      <div class="pt-6 flex justify-center">
        <a href="/" class="btn-primary flex items-center gap-2">
          <Home class="w-5 h-5" />
          Back to Home
        </a>
      </div>
    </div>
  </div>
</Layout>

---
import '../styles/pages/index.css';
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { Terminal, Cpu, Brain, Database, BarChart } from 'lucide-astro';

const featuredProjects = await getCollection('projects', ({ data }) => {
  return data.featured === true;
});

const skills = [
  { name: 'Python',       icon: Terminal },
  { name: 'PyTorch / TF', icon: Cpu      },
  { name: 'Scikit-Learn', icon: Brain    },
  { name: 'Pandas',       icon: Database },
  { name: 'Data Viz',     icon: BarChart },
];
---

<Layout title="Home">

  <section class="hero">
    <div class="hero-left">
      <div class="hero-number" aria-hidden="true">01</div>
      <h1 class="hero-title">
        Mastering <em>Machine</em><br />
        &amp; Deep Learning
      </h1>
    </div>
    <div class="hero-right">
      <p class="hero-desc">
        A professional portfolio documenting my learning path and advanced ML/DL models —
        from scratch to production. Every project is a new lesson.
      </p>
      <div class="hero-btns">
        <a href="/ml-learning-path" class="btn-primary">Start Learning Path</a>
        <a href="/projects"         class="btn-outline">View Projects</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num">12+</span>
          <span class="stat-label">Projects</span>
        </div>
        <div class="stat">
          <span class="stat-num">3+</span>
          <span class="stat-label">Years Learning</span>
        </div>
        <div class="stat">
          <span class="stat-num">5</span>
          <span class="stat-label">Core Skills</span>
        </div>
      </div>
    </div>
  </section>

  <hr class="home-rule" />

  <div class="skills-strip">
    <span class="skills-label">Stack</span>
    {skills.map(s => (
      <div class="skill">
        <s.icon class="w-4 h-4" />
        <span>{s.name}</span>
      </div>
    ))}
  </div>

  <hr class="home-rule" />

  <section class="projects-section">
    <div class="section-header">
      <span class="section-num">02 — Featured</span>
      <div class="section-right">
        <h2 class="section-title">Selected Projects</h2>
        <a href="/projects" class="section-link">View all →</a>
      </div>
    </div>

    {featuredProjects.length > 0 ? (
      <div class="projects-grid">
        {featuredProjects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            image={project.data.image}
            tags={project.data.tags}
            githubLink={project.data.githubLink}
            demoLink={project.data.demoLink}
            slug={project.slug}
          />
        ))}
      </div>
    ) : (
      <p class="empty-note">Projects coming soon.</p>
    )}
  </section>

</Layout>

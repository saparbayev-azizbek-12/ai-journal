---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { Brain, Sparkles, Terminal, Cpu, Database, BarChart } from 'lucide-astro';

const featuredProjects = await getCollection('projects', ({ data }) => {
  return data.featured === true;
});

const skills = [
  { name: 'Python', icon: Terminal, color: 'text-yellow-500' },
  { name: 'PyTorch / TF', icon: Cpu, color: 'text-orange-500' },
  { name: 'Scikit-Learn', icon: Brain, color: 'text-blue-500' },
  { name: 'Pandas', icon: Database, color: 'text-indigo-500' },
  { name: 'Data Viz', icon: BarChart, color: 'text-cyan-500' },
];
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="relative py-20 md:py-32 overflow-hidden">

    <div class="text-center space-y-8 relative z-10">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-brand-accent-secondary animate-fade-in">
        <Sparkles class="w-3 h-3" />
        <span>Exploring the Frontiers of AI</span>
      </div>
      
      <h2 class="text-5xl md:text-7xl font-extrabold tracking-tight">
        Mastering <span class="gradient-text">Machine and Deep Learning</span><br />
        One Project at a Time.
      </h2>
      
      <p class="text-xl text-slate-400 max-w-2xl mx-auto leading-relaxed">
        Welcome to AI Journal. This is my professional portfolio where I document my learning path 
        and showcase advanced ML&DL models from scratch to production.
      </p>

      <div class="flex flex-wrap justify-center gap-4 pt-4">
        <a href="/ml-learning-path" class="btn-primary flex items-center gap-2">
          Start Learning Path
          <Sparkles class="w-4 h-4" />
        </a>
        <a href="/projects" class="btn-ghost">
          View All Projects
        </a>
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section class="py-12 border-y border-white/5 bg-white/[0.02]">
    <div class="max-w-4xl mx-auto flex flex-wrap justify-center gap-8 md:gap-16 items-center px-4">
      {skills.map((skill) => (
        <div class="flex items-center gap-3 group">
          <skill.icon class={`w-6 h-6 ${skill.color} group-hover:scale-110 transition-transform`} />
          <span class="text-sm font-semibold text-slate-300">{skill.name}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="py-24 space-y-12">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div class="space-y-2">
        <h2 class="text-3xl md:text-4xl font-bold">Featured Projects</h2>
        <p class="text-slate-400">Selected work that represents my expertise in ML applications.</p>
      </div>
      <a href="/projects" class="text-brand-accent-primary hover:text-brand-accent-secondary font-medium transition-colors flex items-center gap-2">
        Explore all projects
        <span class="text-lg">→</span>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {featuredProjects.map((project) => (
        <ProjectCard 
          title={project.data.title}
          description={project.data.description}
          image={project.data.image}
          tags={project.data.tags}
          githubLink={project.data.githubLink}
          demoLink={project.data.demoLink}
          slug={project.slug}
        />
      ))}
    </div>
  </section>
</Layout>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
